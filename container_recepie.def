Bootstrap: docker
From: ubuntu:22.04

%arguments
ANTS_VER=2.5.4
C3D_VER=1.0.0

%environment
export ANTSPATH="/opt/ants-{{ ANTS_VER }}/bin"
export ANTSSCRIPTS="/opt/ants-{{ ANTS_VER }}/Scripts"
export DEBIAN_FRONTEND=noninteractive
export TZ=Europe/Brussels
export LD_LIBRARY_PATH="/opt/ants-{{ ANTS_VER }}/lib:$LD_LIBRARY_PATH"
export PATH="$AFNIPATH:$ANTSPATH:$ANTSSCRIPTS:$C3DPATH/bin:$PATH"

%post
# Set install variables, create tmp folder
export TMPDIR="/tmp/general_preproc_build_$( date -u +"%F_%H-%M-%S" )"
[[ -d ${TMPDIR} ]] && rm -rf ${TMPDIR}
mkdir -p ${TMPDIR}
export DEBIAN_FRONTEND=noninteractive
export TZ=Europe/Brussels
apt update -qq
apt install -y -q --no-install-recommends ca-certificates dirmngr gnupg wget

# FIXED: Updated the PPA repository keys and distribution names to match Ubuntu 22.04 (jammy)
wget -qO- "https://keyserver.ubuntu.com/pks/lookup?op=get&search=0xC9A7585B49D51698710F3A115E25F516B04C661B" | gpg --dearmor -o /usr/share/keyrings/marutter-r40.gpg
wget -qO- "https://keyserver.ubuntu.com/pks/lookup?op=get&search=0x6E12762B81063D17BDDD3142F142A4D99F16EB04" | gpg --dearmor -o /usr/share/keyrings/c2d4u40.gpg

echo "deb [signed-by=/usr/share/keyrings/marutter-r40.gpg] https://ppa.launchpadcontent.net/marutter/rrutter4.0/ubuntu jammy main" | tee -a /etc/apt/sources.list
echo "deb-src [signed-by=/usr/share/keyrings/marutter-r40.gpg] https://ppa.launchpadcontent.net/marutter/rrutter4.0/ubuntu jammy main" | tee -a /etc/apt/sources.list
echo "deb [signed-by=/usr/share/keyrings/c2d4u40.gpg] https://ppa.launchpadcontent.net/c2d4u.team/c2d4u4.0+/ubuntu jammy main" | tee -a /etc/apt/sources.list
echo "deb-src [signed-by=/usr/share/keyrings/c2d4u40.gpg] https://ppa.launchpadcontent.net/c2d4u.team/c2d4u4.0+/ubuntu jammy main" | tee -a /etc/apt/sources.list

apt update -qq
apt install -y -q --no-install-recommends \
    bc \
    build-essential \
    bzip2 \
    cmake \
    curl \
    dc \
    file \
    freeglut3-dev \
    g++ \
    gcc \
    git \
    less \
    libcurl4-openssl-dev \
    libeigen3-dev \
    libexpat1-dev \
    libf2c2-dev \
    libfftw3-3 \
    libfftw3-dev \
    libgdal-dev \
    libgfortran5 \
    libgfortran-11-dev \
    libglew-dev \
    libgl1-mesa-dev \
    libgl1-mesa-dri \
    libgl1-mesa-glx \
    libglib2.0-dev \
    libglu1-mesa-dev \
    libglw1-mesa \
    libgomp1 \
    libgsl-dev \
    libgts-dev \
    libjpeg8-dev \
    liblapack3 \
    libopenblas-dev \
    libmotif-dev \
    libnetpbm10-dev \
    libnode-dev \
    libpng-dev \
    libquadmath0 \
    libtiff5 \
    libtiff5-dev \
    libudunits2-dev \
    libxext-dev \
    libxi-dev \
    libxm4 \
    libxmhtml-dev \
    libxml2-dev \
    libxmu-dev \
    libxmu-headers \
    libxpm-dev \
    libxt-dev \
    m4 \
    make \
    mesa-common-dev \
    nano \
    r-base-dev \
    rsync \
    tcsh \
    python3-distutils \
    python3-pip \
    python3-rpy2 \
    python-is-python3 \
    qhull-bin \
    xvfb \
    zlib1g-dev

# Install ANTs
mkdir -p ${TMPDIR}/ants/build
git clone -b v{{ ANTS_VER }} --depth=1 https://github.com/ANTsX/ANTs.git ${TMPDIR}/ants/source
cd ${TMPDIR}/ants/build || exit 1
cmake -DCMAKE_INSTALL_PREFIX=/opt/ants-{{ ANTS_VER }} -DBUILD_SHARED_LIBS=ON -DBUILD_TESTING=OFF ${TMPDIR}/ants/source
make -j 10
mkdir -p /opt/ants-{{ ANTS_VER }}
cd ANTS-build || exit 1
make install
mv ../../source/Scripts/ /opt/ants-{{ ANTS_VER }}
cd ${TMPDIR} || exit 1
rm -rf ${TMPDIR}/ants

# Install pipeline software packages
pip3 install \
    annexremote==1.6.0 \
    boto==2.49.0 \
    certifi==2022.12.7 \
    cffi==1.15.1 \
    chardet==4.0.0 \
    charset-normalizer==2.1.1 \
    contourpy==1.0.6 \
    cryptography==38.0.4 \
    cycler==0.11.0 \
    datalad==0.17.10 \
    dill==0.3.6 \
    distro==1.8.0 \
    fasteners==0.18 \
    fonttools==4.38.0 \
    h5py==3.7.0 \
    humanize==4.4.0 \
    idna==3.4 \
    importlib-metadata==5.1.0 \
    iso8601==1.1.0 \
    jaraco.classes==3.2.3 \
    jeepney==0.8.0 \
    Jinja2==3.1.2 \
    joblib==1.2.0 \
    keyring==23.11.0 \
    keyrings.alt==4.2.0 \
    kiwisolver==1.4.4 \
    lxml==4.9.2 \
    MarkupSafe==2.1.1 \
    matplotlib==3.6.2 \
    more-itertools==9.0.0 \
    msgpack==1.0.4 \
    nibabel==4.0.2 \
    nilearn==0.9.2 \
    numpy==1.23.5 \
    packaging==22.0 \
    pandas==1.5.2 \
    patool==1.12 \
    Pillow==9.3.0 \
    platformdirs==2.6.0 \
    pycparser==2.21 \
    PyOpenGL==3.1.6 \
    pyparsing==2.4.7 \
    python-dateutil==2.8.2 \
    python-gitlab==3.12.0 \
    pytz==2022.6 \
    requests==2.28.1 \
    requests-toolbelt==0.10.1 \
    scikit-learn==1.2.0 \
    scipy==1.9.3 \
    SecretStorage==3.3.3 \
    simplejson==3.18.0 \
    six==1.16.0 \
    threadpoolctl==3.1.0 \
    tqdm==4.64.1 \
    urllib3==1.26.13 \
    Whoosh==2.7.4 \
    zipp==3.11.0

# Additional libraries
pip3 install \
    nigsp==0.19.0 \
    networkx==3.4.2 \
    statsmodels==0.14.6

# Final removal of lists and cleanup
cd /tmp || exit 1
rm -rf ${TMPDIR}
rm -rf /var/lib/apt/lists/*